{
  "manifest_version": 3,
  "name": "NYSR AI Companion",
  "version": "1.0.0",
  "description": "AI-powered content and productivity assistant for NY Spotlight Report operations. Summarize pages, generate content, manage tasks.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://nyspotlightreport.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NYSR AI Companion",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "summarize-page": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "Summarize current page with AI"
    },
    "generate-content": {
      "suggested_key": { "default": "Ctrl+Shift+G" },
      "description": "Generate content from selection"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}